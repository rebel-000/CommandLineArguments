<idea-plugin>
    <extensions defaultExtensionNs="com.intellij">
        <actionPromoter implementation="com.github.rebel000.cmdlineargs.actions.TreeActionPromoter" />
    </extensions>
    <actions resource-bundle="messages.CommandlineArgsActionsBundle">
        <action id="cmdlineargs.collapse-all" class="com.github.rebel000.cmdlineargs.actions.CollapseAllAction" icon="AllIcons.Actions.Collapseall" use-shortcut-of="CollapseRegion" />
        <action id="cmdlineargs.copy-as-plain" class="com.github.rebel000.cmdlineargs.actions.CopyAsPlainTextAction" use-shortcut-of="CopyAsPlainText" />
        <action id="cmdlineargs.disable" class="com.github.rebel000.cmdlineargs.actions.DisableAction" icon="AllIcons.Actions.Pause"/>
        <action id="cmdlineargs.edit" class="com.github.rebel000.cmdlineargs.actions.EditAction" icon="AllIcons.Actions.Edit" use-shortcut-of="ShowIntentionActions" />
        <action id="cmdlineargs.expand-selected" class="com.github.rebel000.cmdlineargs.actions.ExpandSelectedAction" icon="AllIcons.Actions.Expandall" use-shortcut-of="ExpandRegion" />
        <action id="cmdlineargs.move-down" class="com.github.rebel000.cmdlineargs.actions.MoveDownAction" icon="AllIcons.Actions.MoveDown" use-shortcut-of="Arrangement.Rule.Match.Condition.Move.Down" />
        <action id="cmdlineargs.move-up" class="com.github.rebel000.cmdlineargs.actions.MoveUpAction" icon="AllIcons.Actions.MoveUp" use-shortcut-of="Arrangement.Rule.Match.Condition.Move.Up" />
        <action id="cmdlineargs.reload" class="com.github.rebel000.cmdlineargs.actions.ReloadAction" />
        <action id="cmdlineargs.rename" class="com.github.rebel000.cmdlineargs.actions.RenameAction" use-shortcut-of="RenameElement" />
        <action id="cmdlineargs.show-shared" class="com.github.rebel000.cmdlineargs.actions.ShowSharedAction" icon="AllIcons.CodeWithMe.CwmShared" />

        <group id="cmdlineargs.popup.new" class="com.github.rebel000.cmdlineargs.actions.NewActionGroup" icon="AllIcons.General.Add" popup="true" searchable="false" use-shortcut-of="NewElement" />

        <group id="cmdlineargs.toolwindow.toolbar" searchable="false">
            <reference ref="cmdlineargs.popup.new" />
            <reference ref="cmdlineargs.edit" />
            <separator />
            <group id="cmdlineargs.toolwindow.toolbar.copy-as-commandline" class="com.github.rebel000.cmdlineargs.actions.CopyCommandLineActionGroup" icon="AllIcons.Actions.Copy" popup="true" searchable="false" />
            <separator />
            <reference ref="cmdlineargs.expand-selected" />
            <reference ref="cmdlineargs.collapse-all" />
        </group>

        <group id="cmdlineargs.toolwindow.toolbar.ex" searchable="false">
            <group id="cmdlineargs.toolwindow.toolbar.ex.view" class="com.github.rebel000.cmdlineargs.actions.ViewActionGroup" searchable="false" />
            <separator />
            <reference ref="cmdlineargs.disable" />
            <reference ref="cmdlineargs.show-shared" />
            <separator />
            <reference ref="cmdlineargs.reload" />
        </group>

        <group id="cmdlineargs.toolwindow.popup" searchable="false">
            <group id="cmdlineargs.toolwindow.popup.trust" class="com.github.rebel000.cmdlineargs.actions.TrustActionGroup" searchable="false" />
            <reference ref="cmdlineargs.popup.new" />
            <separator />
            <reference ref="$Cut" />
            <reference ref="$Copy" />
            <reference ref="cmdlineargs.copy-as-plain" />
            <reference ref="$Paste" />
            <separator />
            <reference ref="$Delete" />
            <separator />
            <reference ref="cmdlineargs.move-up" />
            <reference ref="cmdlineargs.move-down" />
            <separator />
            <group id="cmdlineargs.toolwindow.popup.quick-params" class="com.github.rebel000.cmdlineargs.actions.QuickParametersActionGroup" searchable="false" />
            <group id="cmdlineargs.toolwindow.popup.filters" class="com.github.rebel000.cmdlineargs.actions.FiltersActionGroup" searchable="false" />
            <separator />
            <reference ref="cmdlineargs.rename" />
            <reference ref="cmdlineargs.edit" />
        </group>
    </actions>
</idea-plugin>
